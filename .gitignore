# Scratch/research docs
.scratch/

# Release artifacts (signed ZIPs, appcast)
releases/

# Temp test output (created by make test)
.test_output

# macOS
.DS_Store
*.swp
*~

# Xcode (Unramble.xcodeproj is generated by XcodeGen from project.yml)
Unramble.xcodeproj/
build/
DerivedData/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
xcuserdata/

# Swift Package Manager
.build/
Packages/
# Ignore resolved files by default, but track the SwiftPM package's so the
# offline test lane (swift test --disable-automatic-resolution) has a pinned
# resolved file to read. Xcode can rewrite it during a build; commit only the
# swift-test form that CI reads.
Package.resolved
!UnrambleKit/Package.resolved

# CocoaPods
Pods/

# Signing
*.mobileprovision
*.p12

# Archives
*.xcarchive

# App bundles
*.app
*.ipa
*.dmg

# Generated model pack (materialized by `make models`, not committed)
UnrambleApp/Resources/models/
UnrambleApp/.model-work/

# Training artifacts (generated by scripts, not committed)
training/adapters/
training/*.jsonl
!training/train.jsonl
!training/valid.jsonl
training/polish-tests.json

# Python bytecode
__pycache__/
*.py[cod]

# Python virtualenv
.venv/

# Environment
.env
.env.*

# IDE
.idea/
.vscode/
*.code-workspace

# Consolidated eval/measurement data (large, not committed)
/data/
